# ============================================================
#  AutoReel — Environment Variables Template
#  Copy this file to .env and fill in your own credentials.
#  NEVER commit the actual .env file to Git.
# ============================================================

# ── PRIMARY AI: Groq (FREE — 14,400 req/day per key) ───────────────────────
# Get keys at: https://console.groq.com
# Add more keys as GROQ_API_KEY_2, _3, etc. for round-robin load balancing.
GROQ_API_KEY_1=gsk_your_first_groq_key_here
GROQ_API_KEY_2=gsk_your_second_groq_key_here

# ── FALLBACK AI: Gemini ──────────────────────────────────────────────────────
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY_1=your_gemini_api_key_here

# ── FALLBACK AI: NVIDIA (Optional) ──────────────────────────────────────────
# Get key at: https://build.nvidia.com
NVIDIA_API_KEY=nvapi-your_nvidia_key_here

# ── FALLBACK AI: OpenRouter (Optional — free models available) ───────────────
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY_1=sk-or-v1-your_openrouter_key_here

# ── B-ROLL VIDEO: Pexels (FREE) ──────────────────────────────────────────────
# Get key at: https://www.pexels.com/api/
PEXELS_API_KEY_1=your_pexels_api_key_here

# ── B-ROLL VIDEO: Pixabay (FREE) ─────────────────────────────────────────────
# Get key at: https://pixabay.com/api/docs/
PIXABAY_API_KEY=your_pixabay_api_key_here

# ── YOUTUBE DATA API (public search) ─────────────────────────────────────────
# Get key at: https://console.cloud.google.com → YouTube Data API v3
YOUTUBE_DATA_API_KEY=AIza_your_youtube_data_api_key_here

# ── TELEGRAM COMMAND CENTER ───────────────────────────────────────────────────
# Create a bot at: https://t.me/BotFather  → /newbot
# Get your chat ID at: https://t.me/userinfobot
TELEGRAM_BOT_TOKEN=1234567890:AAF_your_telegram_bot_token_here
TELEGRAM_CHAT_ID=123456789

# ── TEXT-TO-SPEECH ────────────────────────────────────────────────────────────
# AutoReel uses a 3-tier TTS system — the engine is auto-detected from voice name.
#
# TIER 1 — Microsoft Edge TTS (FREE, no account needed)
#   No setup required. Works out of the box.
#   Set voice_name in your channel JSON to e.g. "en-US-GuyNeural"
#   Full list: python -c "import asyncio, edge_tts; asyncio.run(edge_tts.list_voices())"
#
# TIER 2 — Google Cloud TTS (premium neural voices, requires GCP project)
#   1. Create a GCP project at https://console.cloud.google.com
#   2. Enable "Cloud Text-to-Speech API"
#   3. Create a Service Account and download the JSON credentials
#   4. Save the JSON file to: config/gcp-credentials.json
#   Set voice_name in your channel JSON to e.g. "en-US-Journey-D"
#
# TIER 3 — ElevenLabs (optional, highest quality, key-based)
# Get keys at: https://elevenlabs.io/app/settings/api-keys
# Add more keys as ELEVENLABS_API_KEY_2, _3, etc. for rotation.
ELEVENLABS_API_KEY_1=sk_your_elevenlabs_key_here

# ── FEATURE FLAGS ─────────────────────────────────────────────────────────────
# Set to True to enable autonomous YouTube uploads
AUTO_POST_YOUTUBE=False

# Set to True to skip expensive Gemini clip validation (saves quota)
SKIP_CLIP_VALIDATION=False

# Minimum free disk space (GB) required to start a pipeline run
MIN_DISK_SPACE_GB=2.0
